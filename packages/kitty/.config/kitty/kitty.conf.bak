# BEGIN_KITTY_THEME
# Catppuccin-Mocha
include current-theme.conf
# END_KITTY_THEME

shell /usr/bin/fish --login --interactive


# BEGIN_KITTY_FONTS
font_family      family='GeistMono Nerd Font' postscript_name=GeistMonoNF-Regular
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS