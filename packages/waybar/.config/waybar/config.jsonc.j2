    //==> Right Modules
    ///////////////////////////////////////////////////////////////
    "clock": {
        "format": "{:%H:%M %p}",
        "rotate": 0,
        "format-alt": "{:%R  |  󰃭 %d·%m·%y}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='{{ colors.hex.dark.petal }}'><b>{}</b></span>",
                "weekdays": "<span color='{{ colors.hex.dark.coral }}'><b>{}</b></span>",
                "today": "<span color='{{ colors.hex.dark.crimson }}'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "rotate": 0,
        "format-icons": {
            "activated": "󰥔 ",
            "deactivated": " "
        }
    },
    "custom/battery": {
        "exec": "bash ~/.local/bin/battery.sh --status --discharged-color \"{{ colors.hex.dark.crimson }}\" --charged-color \"{{ colors.hex.dark.verdant }}\" | cat",
        "return-type": "raw",
	    "format": "{}  ",
        "interval": 3,
	    "rotate": 0,
	    "on-click": "bash ~/.local/bin/battery.sh --notify",
        "tooltip": false
    },
    "custom/brightness": {
        "exec": "bash ~/.local/bin/brightness.sh --status --color \"{{ colors.hex.dark.aether }}\" | cat",
        "return-type": "raw",
        "format": "{}  ",
        "interval": 1,
        "rotate": 0,
        "on-scroll-up": "bash ~/.local/bin/brightness.sh --up",
        "on-scroll-down": "bash ~/.local/bin/brightness.sh --down",
        "on-click-left": "bash ~/.local/bin/brightness.sh --max",
        "on-click-right": "bash ~/.local/bin/brightness.sh --min",
        "tooltip": false
    },
	"custom/volume": {
        "exec": "bash ~/.local/bin/volume.sh --device output --status --disabled-color \"{{ colors.hex.dark.crimson }}\" --enabled-color \"{{ colors.hex.dark.verdant }}\" | cat",
        "return-type": "raw",
	    "format": "{}  ",
        "interval": 1,
	    "rotate": 0,
	    "on-click": "bash ~/.local/bin/volume.sh --device output --action toggle",
	    "on-scroll-up": "bash ~/.local/bin/volume.sh --device output --action increase",
	    "on-scroll-down": "bash ~/.local/bin/volume.sh --device output --action decrease",
	    "scroll-step": 5,
        "tooltip": false
	},
    "custom/microphone": {
        "exec": "bash ~/.local/bin/volume.sh --device input --status --disabled-color \"{{ colors.hex.dark.crimson }}\" --enabled-color \"{{ colors.hex.dark.verdant }}\" | cat",
        "return-type": "raw",
	    "format": "{}",
        "interval": 1,
	    "rotate": 0,
	    "on-click": "bash ~/.local/bin/volume.sh --device input --action toggle",
	    "on-scroll-up": "bash ~/.local/bin/volume.sh --device input --action increase",
	    "on-scroll-down": "bash ~/.local/bin/volume.sh --device input --action decrease",
	    "scroll-step": 5,
        "tooltip": false
	},
	"hyprland/language": {
        "format": "{short} {variant}",
        "rotate": 0,
        "min-length": 2,
        "tooltip": false
    },
    "custom/system-update": {
        "exec": "bash ~/.local/bin/system-update.sh --status --unupdated-color \"{{ colors.hex.dark.amber }} \" --updated-color \"{{ colors.hex.dark.verdant }}\" | cat",
        "return-type": "raw",
        "format": "{} ",
        "rotate": 0,
        "on-click": "CHECKUPDATES_DB=\"/tmp/checkup-db-${UID}-$$\" bash ~/.local/bin/system-update.sh",
        "interval": 86400,
        "tooltip": false
    },
    "custom/do-not-disturb": {
        "exec": "bash ~/.local/bin/do-not-disturb.sh --status --disabled-color \"{{ colors.hex.dark.crimson }}\" --enabled-color \"{{ colors.hex.dark.verdant }}\" | cat",
        "return-type": "raw",
        "format": "{} ",
        "interval": 1,
        "rotate": 0,
        "on-click": "bash ~/.local/bin/do-not-disturb.sh",
        "tooltip": false
    },
    "custom/screenshot": {
        "on-click": "bash ~/.local/bin/rofi/screenshot.sh",
        "format": "<span color=\"{{ colors.hex.dark.aether }}\">⎙  </span>",
        "rotate": 0,
        "tooltip": false
    },
    "custom/vpn": {
        "exec": "bash ~/.local/bin/rofi/vpn-manager.sh --status --disabled-color \"{{ colors.hex.dark.crimson }}\" --enabled-color \"{{ colors.hex.dark.verdant }}\" | cat",
        "return-type": "raw",
        "format": "{} ",
        "interval": 3,
        "rotate": 0,
        "on-click": "bash ~/.local/bin/rofi/vpn-manager.sh",
        "tooltip": false
    },
    "custom/bluetooth": {
        "format": "<span color=\"{{ colors.hex.dark.aether }}\">󰂯  </span>",
        "interval": 3,
        "rotate": 0,
        "on-click": "blueman-manager",
        "tooltip": false
    },
    "custom/networkmanager": {
        "exec": "bash ~/.local/bin/rofi/network-manager.sh --status --disabled-color \"{{ colors.hex.dark.crimson }}\" --enabled-color \"{{ colors.hex.dark.verdant }}\" | cat",
        "return-type": "raw",
        "format": "{}  ",
        "interval": 3,
        "rotate": 0,
        "on-click": "bash ~/.local/bin/rofi/network-manager.sh",
        "tooltip": false
    },
    "custom/power": {
        "on-click": "bash ~/.local/bin/rofi/powermenu.sh",
        "format": "<span color=\"{{ colors.hex.dark.crimson }}\"> </span>",
        "rotate": 0,
        "tooltip": false
    },

	
    //==> Other Modules
    ///////////////////////////////////////////////////////////////
    "custom/l_end": {
        "format": " ",
        "interval" : "once",
        "tooltip": false
    },

    "custom/r_end": {
        "format": " ",
        "interval" : "once",
        "tooltip": false
    },

    "custom/padd": {
        "format": "  ",
        "interval" : "once",
        "tooltip": false
    },

    "custom/padd_bg": {
        "format": "  ",
        "interval" : "once",
        "tooltip": false
    }
}