{
    "layer": "top",
    "position": "top",
    "mod": "dock",
    "height": 40,
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "reload_style_on_change": true,

    //==> Modules Layout
    ///////////////////////////////////////////////////////////////
	"modules-left": [
		"custom/l_end","tray","custom/r_end","custom/l_end","hyprland/workspaces","custom/r_end","custom/l_end","wlr/taskbar","custom/r_end","custom/padd"
	],
	// "modules-center": [
	// 	"group/system-info"
	// ],
	"modules-right": [
		"group/system-levels",
		"custom/l_end","idle_inhibitor","clock","custom/r_end",
        "custom/l_end","hyprland/language","custom/r_end",
		"group/control-panel", "custom/padd"
	],
    // "group/system-info": {
	// 	"orientation": "horizontal",
	// 	"modules": [
	// 		"custom/cpu",
	// 		"custom/ram",
	// 		"custom/gpu"
	// 	]
	// },
	"group/system-levels": {
		"orientation": "horizontal",
		"modules": [
            "custom/l_end",
			// "custom/brightness",
			"custom/battery",
			"custom/volume",
			"custom/microphone",
            "custom/r_end"
		]
	},
	"group/control-panel": {
		"orientation": "horizontal",
		"modules": [
            "custom/l_end",
			"custom/system-update",
            "custom/screenshot",
			// "custom/do-not-disturb",
			// "custom/vpn",
			"custom/bluetooth",
			// "custom/networkmanager",
			"custom/power",
            "custom/r_end"
		]
	},
        
    //==> Left Modules
    ///////////////////////////////////////////////////////////////
    "tray": {
        "icon-size": 18,
        "rotate": 0,
        "spacing": 4
    },
    "hyprland/workspaces": {
        "rotate": 0,
        "all-outputs": true,
        "active-only": false,
        "on-click": "activate",
        "disable-scroll": false,
        "on-scroll-up": "hyprctl dispatch workspace -1",
        "on-scroll-down": "hyprctl dispatch workspace +1",
        "persistent-workspaces": {}
    },
	"wlr/taskbar": {
		"format": "{icon}",
		"rotate": 0,
		"icon-size": 20,
		"icon-theme": "Tela-circle-dracula",
        "spacing": 0,
		"tooltip-format": "{title}",
		"on-click": "activate",
		"on-click-middle": "close",
		"app_ids-mapping": {
			"firefoxdeveloperedition": "firefox-developer-edition"
		}
	},



